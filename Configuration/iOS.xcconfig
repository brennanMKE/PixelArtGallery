
ASSETCATALOG_COMPILER_APPICON_NAME[sdk=iphone*] = AppIcon-iOS
MY_CUSTOM_BUILD_SETTING[sdk=iphone*] = IPHONE

// iOS keeps the Xcode-generated Info.plist; macOS uses a file (see macOS.xcconfig, #0039).
GENERATE_INFOPLIST_FILE[sdk=iphone*] = YES

INFOPLIST_KEY_UIApplicationSceneManifest_Generation[sdk=iphone*] = YES
INFOPLIST_KEY_UIApplicationSupportsIndirectInputEvents[sdk=iphone*] = YES
INFOPLIST_KEY_UILaunchScreen_Generation[sdk=iphone*] = YES
